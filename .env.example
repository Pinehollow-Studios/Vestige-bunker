# Supabase project the admin dashboard reads/writes against.
# Dev: Vestige-iOS-Dev (matches CLAUDE.md §3.8).
# Prod: vestige-ios-prod (provisioned at Phase 11; staging gets prod URL when it lands).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Origin used to build magic-link redirect URLs. http://localhost:3000 in dev,
# the deployed origin (e.g. https://admin.vestige.app) in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry Web API access — drives the lazy stack-trace + breadcrumbs
# pull on /crashes/[id]. All three must be set together; with any
# missing the detail page renders a "Sentry not configured" inline
# placeholder and the local crash row is the only data shown. The
# crashes queue itself works without these — it reads from the
# `crash_reports` table populated by the `sentry-webhook` Edge
# Function. See `Vestige-ios/docs/sentry-setup.md`.
#
# SENTRY_AUTH_TOKEN  — Internal Integration auth token. Mint at
#                      sentry.io → pinehollow-studios → Settings →
#                      Developer Settings → vestige-admin → Tokens.
#                      Permissions: Project: Read, Issue & Event:
#                      Read, Member: Read.
# SENTRY_ORG_SLUG    — `pinehollow-studios`.
# SENTRY_PROJECT_SLUG — `vestige-ios`.
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=pinehollow-studios
SENTRY_PROJECT_SLUG=vestige-ios
